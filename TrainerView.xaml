<UserControl x:Class="Voice.TrainerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Voice"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="800"
             TextOptions.TextFormattingMode="Display"
             UseLayoutRounding="True">
    <Grid Background="Transparent" Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="Vocal Training Hub" 
                       FontFamily="Calibri" 
                       FontSize="26" 
                       FontWeight="Bold" 
                       Foreground="{StaticResource TextPrimaryBrush}"/>
            <TextBlock Text="Select a vocal property and target zone, click Start, and practice matching the goal in real time." 
                       FontFamily="Calibri" 
                       FontSize="13" 
                       Foreground="{StaticResource TextSecondaryBrush}"/>
        </StackPanel>

        <!-- Config Panel -->
        <Border Grid.Row="1" Style="{StaticResource CardPanel}" Padding="16,12" Margin="0,0,0,20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="1. Select Vocal Metric" FontFamily="Calibri" FontWeight="Bold" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,6"/>
                    <ComboBox x:Name="MetricSelector" Padding="10,6" SelectedIndex="0" SelectionChanged="MetricSelector_SelectionChanged">
                        <ComboBoxItem Content="Vocal Pitch (F0)"/>
                        <ComboBoxItem Content="Vocal Resonance (Formants)"/>
                    </ComboBox>
                </StackPanel>

                <StackPanel Grid.Column="2">
                    <TextBlock Text="2. Select Target Zone" FontFamily="Calibri" FontWeight="Bold" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,6"/>
                    <ComboBox x:Name="TargetSelector" Padding="10,6" SelectedIndex="1" SelectionChanged="TargetSelector_SelectionChanged">
                        <ComboBoxItem Content="Masculine Zone"/>
                        <ComboBoxItem Content="Androgynous Zone"/>
                        <ComboBoxItem Content="Feminine Zone"/>
                    </ComboBox>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Practice Canvas Card -->
        <Border Grid.Row="2" Style="{StaticResource CardPanel}" Padding="0" Margin="0,0,0,20">
            <Grid ClipToBounds="True">
                <!-- Scrolling Chart Canvas -->
                <Canvas x:Name="ChartCanvas" Background="#FAFBFC" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                    <!-- Shaded Target Band -->
                    <Border x:Name="TargetBand" 
                            Background="#D1FAE5" 
                            BorderBrush="#34D399" 
                            BorderThickness="0,1,0,1" 
                            Opacity="0.5" 
                            Width="{Binding ElementName=ChartCanvas, Path=ActualWidth}"
                            Canvas.Left="0"/>
                    
                    <!-- Line representing speaker's inputs -->
                    <Polyline x:Name="TrainerPolyline" 
                              Stroke="{StaticResource AccentBrush}" 
                              StrokeThickness="3" 
                              StrokeLineJoin="Round"/>
                </Canvas>

                <!-- Grid labels for visual feedback -->
                <Grid Margin="12,12,0,12" HorizontalAlignment="Left" IsHitTestVisible="False">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock x:Name="MaxYLabel" Grid.Row="0" Text="300 Hz" FontSize="10" FontWeight="Bold" Foreground="{StaticResource TextSecondaryBrush}"/>
                    <TextBlock x:Name="MidYLabel" Grid.Row="1" Text="180 Hz" FontSize="10" FontWeight="Bold" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                    <TextBlock x:Name="MinYLabel" Grid.Row="2" Text="50 Hz" FontSize="10" FontWeight="Bold" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Bottom"/>
                </Grid>

                <TextBlock x:Name="TargetBandLabel" 
                           Text="TARGET ZONE" 
                           FontSize="10" 
                           FontWeight="Bold" 
                           Foreground="#065F46" 
                           HorizontalAlignment="Right" 
                           VerticalAlignment="Center" 
                           Margin="0,0,16,0" 
                           Opacity="0.7"
                           IsHitTestVisible="False"/>
            </Grid>
        </Border>

        <!-- Controls & Coaching feedback -->
        <Border Grid.Row="3" Style="{StaticResource CardPanel}" Padding="20,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="2*"/>
                </Grid.ColumnDefinitions>

                <!-- Left Column: Live Value -->
                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock x:Name="ValueTitle" Text="Live Output" FontFamily="Calibri" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"/>
                    <TextBlock x:Name="LiveValueText" Text="---" FontFamily="Calibri" FontSize="24" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,2,0,0"/>
                </StackPanel>

                <!-- Center Column: Toggle Start -->
                <Button x:Name="StartBtn" 
                        Grid.Column="1" 
                        Content="Start Live Practice" 
                        Style="{StaticResource PrimaryButton}" 
                        Padding="24,14" 
                        Click="StartBtn_Click"/>

                <!-- Right Column: Coach Text -->
                <StackPanel Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Right">
                    <TextBlock Text="Coaching Tip" FontFamily="Calibri" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Right"/>
                    <TextBlock x:Name="CoachingTipText" 
                               Text="Click Start and vocalize to begin." 
                               FontFamily="Calibri" 
                               FontSize="14" 
                               FontWeight="SemiBold" 
                               Foreground="{StaticResource AccentBrush}" 
                               HorizontalAlignment="Right" 
                               Margin="0,2,0,0"
                               TextAlignment="Right"
                               TextWrapping="Wrap"
                               MaxWidth="250"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
