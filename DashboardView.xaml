<UserControl x:Class="Voice.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Voice"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="800"
             TextOptions.TextFormattingMode="Display"
             UseLayoutRounding="True">
    <Grid Background="Transparent" Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Top Header Panel -->
        <StackPanel Grid.Row="0" Margin="0,0,0,24">
            <TextBlock Text="Voice Capture &amp; Live Feedback" 
                       FontFamily="Calibri" 
                       FontSize="26" 
                       FontWeight="Bold" 
                       Foreground="{StaticResource TextPrimaryBrush}"/>
            <TextBlock Text="Press record, speak normally for a few seconds, and stop. We'll analyze pitch, spectral brightness, spectral balance, and timing."
                       FontFamily="Calibri" 
                       FontSize="14" 
                       Foreground="{StaticResource TextSecondaryBrush}" 
                       Margin="0,4,0,0"
                       TextWrapping="Wrap"/>
        </StackPanel>

        <!-- Waveform and Prompts Side by Side -->
        <Grid Grid.Row="1" Margin="0,0,0,24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.5*"/>
                <ColumnDefinition Width="20"/> <!-- Gap -->
                <ColumnDefinition Width="1.1*"/>
            </Grid.ColumnDefinitions>

            <!-- Live pitch contour (Left Column) -->
            <Border Grid.Column="0" Style="{StaticResource CardPanel}" Padding="0">
                <Grid ClipToBounds="True">
                    <!-- A scrolling F0 trace. The horizontal axis is time, not frequency. -->
                    <Canvas x:Name="WaveCanvas" Background="#FFFFFF" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                        <Rectangle x:Name="LiveMasculineBand" Fill="#FEF2F2"/>
                        <Rectangle x:Name="LiveAndrogynousBand" Fill="#FFFBEB"/>
                        <Rectangle x:Name="LiveFeminineBand" Fill="#EFF6FF"/>
                        <Path x:Name="GridLinesPath" Stroke="#F1F5F9" StrokeThickness="1" Fill="Transparent"/>
                        <Path x:Name="LivePitchPath" Stroke="{StaticResource AccentBrush}" StrokeThickness="2.5" StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                    </Canvas>

                    <TextBlock Text="Live F0 contour" FontSize="11" FontWeight="Bold" Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="14,12,0,0" IsHitTestVisible="False"/>
                    <TextBlock Text="300 Hz" FontSize="10" Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="14,30,0,0" IsHitTestVisible="False"/>
                    <TextBlock Text="180 Hz" FontSize="10" Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="14,0,0,0" IsHitTestVisible="False"/>
                    <TextBlock Text="65 Hz" FontSize="10" Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="14,0,0,52" IsHitTestVisible="False"/>

                    <!-- Centered Information Overlay (when idle) -->
                    <StackPanel x:Name="VisualizerOverlay" 
                                HorizontalAlignment="Center" 
                                VerticalAlignment="Center" 
                                IsHitTestVisible="False">
                        <TextBlock x:Name="VisualizerOverlayText" 
                                   Text="Microphone Idle" 
                                   FontFamily="Calibri" 
                                   FontSize="16" 
                                   FontWeight="SemiBold" 
                                   Foreground="{StaticResource TextSecondaryBrush}" 
                                   HorizontalAlignment="Center"/>
                        <TextBlock x:Name="VisualizerOverlaySubtext" 
                                   Text="A live pitch curve will appear here during capture"
                                   FontFamily="Calibri" 
                                   FontSize="12" 
                                   Foreground="#A0AEC0" 
                                   HorizontalAlignment="Center" 
                                   Margin="0,4,0,0"/>
                    </StackPanel>

                    <!-- Live stats strip overlay -->
                    <Border VerticalAlignment="Bottom" 
                            Background="#F0FFFFFF" 
                            BorderBrush="{StaticResource BorderBrush}" 
                            BorderThickness="0,1,0,0" 
                            Padding="16,10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Orientation="Horizontal" Grid.Column="0">
                                <TextBlock Text="Live Pitch: " FontFamily="Calibri" FontWeight="Bold" Foreground="{StaticResource TextSecondaryBrush}"/>
                                <TextBlock x:Name="LivePitchText" Text="--- Hz" FontFamily="Calibri" FontWeight="Bold" Foreground="{StaticResource AccentBrush}" Margin="4,0,0,0"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Grid.Column="1">
                                <TextBlock Text="Duration: " FontFamily="Calibri" FontWeight="Bold" Foreground="{StaticResource TextSecondaryBrush}"/>
                                <TextBlock x:Name="LiveTimerText" Text="0.0s" FontFamily="Calibri" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}" Margin="4,0,0,0"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>
            </Border>

            <!-- Reading Prompts Card (Right Column) -->
            <Border Grid.Column="2" Style="{StaticResource CardPanel}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/> <!-- Title -->
                        <RowDefinition Height="Auto"/> <!-- Category Dropdown & Cycle -->
                        <RowDefinition Height="*"/>    <!-- Text display -->
                        <RowDefinition Height="Auto"/> <!-- Note -->
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="Reading Prompt Assistant" FontFamily="Calibri" FontSize="15" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,10"/>

                    <Grid Grid.Row="1" Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <ComboBox x:Name="PromptCategoryCombo" Grid.Column="0" Padding="8,5" Margin="0,0,6,0" SelectionChanged="PromptCategoryCombo_SelectionChanged"/>
                        <Button x:Name="PrevPromptBtn" Grid.Column="1" Content="◀" Style="{StaticResource PrimaryButton}" Padding="10,5" Margin="0,0,4,0" FontSize="11" Click="PrevPrompt_Click"/>
                        <Button x:Name="NextPromptBtn" Grid.Column="2" Content="▶" Style="{StaticResource PrimaryButton}" Padding="10,5" FontSize="11" Click="NextPrompt_Click"/>
                    </Grid>

                    <Border Grid.Row="2" Background="#F8FAFC" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="8" Padding="12">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <TextBlock x:Name="SelectedPromptText" 
                                       Text="Please select a prompt category." 
                                       FontFamily="Calibri" 
                                       FontSize="13.5" 
                                       FontWeight="Medium" 
                                       Foreground="{StaticResource TextPrimaryBrush}" 
                                       TextWrapping="Wrap" 
                                       LineHeight="20"/>
                        </ScrollViewer>
                    </Border>

                    <TextBlock x:Name="PromptNoteText" 
                               Grid.Row="3" 
                               Text="Note: Select category above to load speech prompts." 
                               FontSize="10.5" 
                               FontStyle="Italic" 
                               Foreground="{StaticResource TextSecondaryBrush}" 
                               Margin="0,10,0,0" 
                               TextWrapping="Wrap"/>
                </Grid>
            </Border>
        </Grid>

        <!-- Controls Panel -->
        <Border Grid.Row="2" Style="{StaticResource CardPanel}" Padding="20,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="2*"/>
                </Grid.ColumnDefinitions>

                <!-- Left Column: Audio Status -->
                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock x:Name="StatusTitle" 
                               Text="Ready to capture" 
                               FontFamily="Calibri" 
                               FontSize="15" 
                               FontWeight="Bold" 
                               Foreground="{StaticResource TextPrimaryBrush}"/>
                    <TextBlock x:Name="StatusSubtitle" 
                               Text="Click the red button to start recording." 
                               FontFamily="Calibri" 
                               FontSize="12" 
                               Foreground="{StaticResource TextSecondaryBrush}" 
                               Margin="0,2,0,0"
                               TextWrapping="Wrap"/>
                </StackPanel>

                <!-- Center Column: Recording Controls -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <!-- Playback button (hidden initially) -->
                    <Button x:Name="PlayButton" 
                            Style="{StaticResource PrimaryButton}" 
                            Background="#10B981" 
                            Padding="16,10"
                            Margin="0,0,20,0"
                            Visibility="Collapsed"
                            Click="PlayButton_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE768;" FontFamily="Segoe MDL2 Assets" FontSize="11" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Playback" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    
                    <!-- Record / Stop Button -->
                    <Button x:Name="RecordBtn" 
                            Style="{StaticResource RecordButtonStyle}"
                            Click="RecordBtn_Click">
                        <TextBlock x:Name="RecordBtnText" 
                                   Text="●" 
                                   FontSize="24" 
                                   Foreground="White" 
                                   Margin="0,0,0,2"/>
                    </Button>
                </StackPanel>

                <!-- Right Column: Navigation Actions -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Button x:Name="AnalyzeBtn" 
                            Content="Analyze Recording →" 
                            Style="{StaticResource PrimaryButton}" 
                            IsEnabled="False"
                            Click="AnalyzeBtn_Click"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
