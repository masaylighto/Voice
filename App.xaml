<Application x:Class="Voice.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:Voice"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <!-- Global Value Converters -->
        <local:BlockProgressBarConverter x:Key="BlockProgressBarConverter"/>

        <!-- Premium Slate/Indigo Color Palette -->
        <Color x:Key="WindowBgColor">#F8FAFC</Color>     <!-- Tailwind Slate 50 -->
        <Color x:Key="CardBgColor">#FFFFFF</Color>       <!-- Pure White -->
        <Color x:Key="BorderColor">#E2E8F0</Color>       <!-- Tailwind Slate 200 -->
        <Color x:Key="TextPrimaryColor">#0F172A</Color>   <!-- Tailwind Slate 900 -->
        <Color x:Key="TextSecondaryColor">#475569</Color> <!-- Tailwind Slate 600 -->
        <Color x:Key="AccentColor">#4F46E5</Color>       <!-- Indigo 600 -->
        <Color x:Key="AccentHoverColor">#4338CA</Color>   <!-- Indigo 700 -->

        <!-- Vocal Range Spectrum Colors -->
        <Color x:Key="MaleColor">#0ea5e9</Color>     <!-- Sky Blue 500 -->
        <Color x:Key="AndroColor">#8b5cf6</Color>    <!-- Violet 500 -->
        <Color x:Key="FemaleColor">#ec4899</Color>   <!-- Pink 500 -->

        <SolidColorBrush x:Key="WindowBgBrush" Color="{StaticResource WindowBgColor}"/>
        <SolidColorBrush x:Key="CardBgBrush" Color="{StaticResource CardBgColor}"/>
        <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource BorderColor}"/>
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimaryColor}"/>
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondaryColor}"/>
        <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}"/>
        <SolidColorBrush x:Key="AccentHoverBrush" Color="{StaticResource AccentHoverColor}"/>
        
        <SolidColorBrush x:Key="MaleBrush" Color="{StaticResource MaleColor}"/>
        <SolidColorBrush x:Key="AndroBrush" Color="{StaticResource AndroColor}"/>
        <SolidColorBrush x:Key="FemaleBrush" Color="{StaticResource FemaleColor}"/>

        <!-- Linear Gradients for Gauges -->
        <LinearGradientBrush x:Key="GenderRangeGradient" StartPoint="0,0" EndPoint="1,0">
            <GradientStop Color="#0ea5e9" Offset="0.0"/>   <!-- Male (Sky Blue) -->
            <GradientStop Color="#0d9488" Offset="0.3"/>   <!-- Masculine-leaning Andro (Teal) -->
            <GradientStop Color="#8b5cf6" Offset="0.5"/>   <!-- Neutral Andro (Purple) -->
            <GradientStop Color="#d946ef" Offset="0.7"/>   <!-- Feminine-leaning Andro (Magenta) -->
            <GradientStop Color="#ec4899" Offset="1.0"/>   <!-- Female (Rose Pink) -->
        </LinearGradientBrush>

        <!-- Extremely Subtle Premium Drop Shadow -->
        <DropShadowEffect x:Key="SoftShadow" 
                          Color="#0F172A" 
                          Opacity="0.04" 
                          BlurRadius="24" 
                          ShadowDepth="2" 
                          Direction="270"/>

        <DropShadowEffect x:Key="ButtonGlow" 
                          Color="{StaticResource AccentColor}" 
                          Opacity="0.08" 
                          BlurRadius="12" 
                          ShadowDepth="0"/>

        <!-- Modern Card Style -->
        <Style TargetType="Border" x:Key="CardPanel">
            <Setter Property="Background" Value="{StaticResource CardBgBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="24"/>
            <Setter Property="Effect" Value="{StaticResource SoftShadow}"/>
        </Style>

        <!-- Flat/Modern Scrollbar Customization -->
        <Style TargetType="ScrollBar">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width" Value="6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid x:Name="Bg" SnapsToDevicePixels="true">
                            <Track x:Name="PART_Track" IsDirectionReversed="true" IsEnabled="{TemplateBinding IsEnabled}">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="{x:Static ScrollBar.PageUpCommand}" Opacity="0"/>
                                </Track.DecreaseRepeatButton>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="{x:Static ScrollBar.PageDownCommand}" Opacity="0"/>
                                </Track.IncreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Background="#E2E8F0" Width="6">
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border Background="{TemplateBinding Background}" CornerRadius="3"/>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Modern Navigation Button Style -->
        <Style TargetType="RadioButton" x:Key="NavButton">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Border" 
                                Background="Transparent" 
                                CornerRadius="8" 
                                Padding="16,12" 
                                Margin="0,3"
                                SnapsToDevicePixels="True">
                            <Grid>
                                <!-- Selected highlight left bar -->
                                <Border x:Name="ActiveIndicator" 
                                        HorizontalAlignment="Left" 
                                        Background="{StaticResource AccentBrush}" 
                                        Width="3.5" 
                                        Height="18" 
                                        CornerRadius="1.5"
                                        Margin="-16,0,0,0"
                                        Visibility="Collapsed"/>
                                
                                <ContentPresenter VerticalAlignment="Center" Margin="0,0,0,0"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#F1F5F9"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#EEF2FF"/>
                                <Setter Property="TextElement.Foreground" Value="{StaticResource AccentBrush}"/>
                                <Setter TargetName="ActiveIndicator" Property="Visibility" Value="Visible"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="FontFamily" Value="Calibri"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <!-- Primary Action Button Style -->
        <Style TargetType="Button" x:Key="PrimaryButton">
            <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontFamily" Value="Calibri"/>
            <Setter Property="FontSize" Value="14.5"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Border" 
                                Background="{TemplateBinding Background}" 
                                CornerRadius="8" 
                                Padding="{TemplateBinding Padding}" 
                                SnapsToDevicePixels="True"
                                Effect="{StaticResource ButtonGlow}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="{StaticResource AccentHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#3730A3"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Border" Property="Background" Value="#F1F5F9"/>
                                <Setter Property="Foreground" Value="#94A3B8"/>
                                <Setter TargetName="Border" Property="Effect" Value="{x:Null}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Secondary Action Button Style -->
        <Style TargetType="Button" x:Key="SecondaryButton">
            <Setter Property="Background" Value="#F1F5F9"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="FontFamily" Value="Calibri"/>
            <Setter Property="FontSize" Value="13.5"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#CBD5E1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Border" 
                                Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6" 
                                Padding="{TemplateBinding Padding}" 
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#E2E8F0"/>
                                <Setter TargetName="Border" Property="BorderBrush" Value="#94A3B8"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#CBD5E1"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Border" Property="Background" Value="#F8FAFC"/>
                                <Setter Property="Foreground" Value="#CBD5E1"/>
                                <Setter TargetName="Border" Property="BorderBrush" Value="#E2E8F0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Circular Glowing Record Button Style -->
        <Style TargetType="Button" x:Key="RecordButtonStyle">
            <Setter Property="Background" Value="#EF4444"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Width" Value="70"/>
            <Setter Property="Height" Value="70"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <!-- Outer Breathing Ring -->
                            <Ellipse x:Name="OuterRing" Fill="#EF4444" Opacity="0.15" Margin="-6"/>
                            <!-- Core Button -->
                            <Ellipse x:Name="Core" Fill="{TemplateBinding Background}">
                                <Ellipse.Effect>
                                    <DropShadowEffect Color="#EF4444" Opacity="0.25" BlurRadius="12" ShadowDepth="0"/>
                                </Ellipse.Effect>
                            </Ellipse>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Core" Property="Fill" Value="#DC2626"/>
                                <Setter TargetName="OuterRing" Property="Margin" Value="-9"/>
                                <Setter TargetName="OuterRing" Property="Opacity" Value="0.25"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Core" Property="Fill" Value="#B91C1C"/>
                                <Setter TargetName="OuterRing" Property="Margin" Value="-3"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Custom Styled Slider for Male vs Andro vs Female Gauge -->
        <Style TargetType="Slider" x:Key="GaugeSliderStyle">
            <Setter Property="IsHitTestVisible" Value="False"/>
            <Setter Property="Minimum" Value="0"/>
            <Setter Property="Maximum" Value="100"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            
                            <!-- Thicker Spectrum Track with Scale ticks -->
                            <Border Grid.Row="0" 
                                    Height="10" 
                                    Background="{StaticResource GenderRangeGradient}" 
                                    CornerRadius="5" 
                                    BorderBrush="#CBD5E1" 
                                    BorderThickness="1"
                                    Margin="0,8"
                                    ClipToBounds="True">
                                <!-- Calibrated Scientific Scale Grid Overlay -->
                                <UniformGrid Columns="10" Margin="0" IsHitTestVisible="False" Opacity="0.12">
                                    <Border BorderBrush="Black" BorderThickness="0,0,1,0" Margin="0,0,-0.5,0"/>
                                    <Border BorderBrush="Black" BorderThickness="0,0,1,0" Margin="0,0,-0.5,0"/>
                                    <Border BorderBrush="Black" BorderThickness="0,0,1,0" Margin="0,0,-0.5,0"/>
                                    <Border BorderBrush="Black" BorderThickness="0,0,1,0" Margin="0,0,-0.5,0"/>
                                    <Border BorderBrush="Black" BorderThickness="0,0,1,0" Margin="0,0,-0.5,0"/>
                                    <Border BorderBrush="Black" BorderThickness="0,0,1,0" Margin="0,0,-0.5,0"/>
                                    <Border BorderBrush="Black" BorderThickness="0,0,1,0" Margin="0,0,-0.5,0"/>
                                    <Border BorderBrush="Black" BorderThickness="0,0,1,0" Margin="0,0,-0.5,0"/>
                                    <Border BorderBrush="Black" BorderThickness="0,0,1,0" Margin="0,0,-0.5,0"/>
                                    <Border BorderBrush="Black" BorderThickness="0,0,0,0"/>
                                </UniformGrid>
                            </Border>
                            
                            <!-- Pointer Marker (horizontal track) -->
                            <Track x:Name="PART_Track" Grid.Row="0" Orientation="Horizontal">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="Slider.DecreaseLarge" Opacity="0"/>
                                </Track.DecreaseRepeatButton>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="Slider.IncreaseLarge" Opacity="0"/>
                                </Track.IncreaseRepeatButton>
                                <Track.Thumb>
                                    <!-- High-performance Capsule/Pill Indicator to prevent edge clipping -->
                                    <Thumb Width="10" Height="20">
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border Width="10" Height="20" Background="#0F172A" BorderBrush="White" BorderThickness="1.5" CornerRadius="5">
                                                    <Border.Effect>
                                                        <DropShadowEffect BlurRadius="4" ShadowDepth="1" Opacity="0.3"/>
                                                    </Border.Effect>
                                                </Border>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Modern Clean ComboBox Style (Basic Properties Override) -->
        <Style TargetType="ComboBox">
            <Setter Property="FontFamily" Value="Calibri"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
    </Application.Resources>
</Application>
