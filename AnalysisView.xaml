<UserControl x:Class="Voice.AnalysisView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Voice"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="900"
             TextOptions.TextFormattingMode="Display"
             UseLayoutRounding="True">
    <Grid Background="Transparent" Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Top Header & Classification -->
        <Border Grid.Row="0" Style="{StaticResource CardPanel}" Padding="20,16" Margin="0,0,0,20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <StackPanel Grid.Column="0">
                    <TextBlock Text="Vocal Analysis Profile" 
                               FontFamily="Calibri" 
                               FontSize="22" 
                               FontWeight="Bold" 
                               Foreground="{StaticResource TextPrimaryBrush}"/>
                    <TextBlock Text="Pitch is measured across the full recording. The pitch profile is an acoustic reference, not an identity label."
                               FontFamily="Calibri" 
                               FontSize="13" 
                               Foreground="{StaticResource TextSecondaryBrush}"/>
                </StackPanel>
                
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button x:Name="RawMetricsBtn" 
                            Content="Copy Measurements"
                            Style="{StaticResource SecondaryButton}" 
                            Padding="12,6" 
                            FontSize="12" 
                            Margin="0,0,12,0"
                            Click="RawMetricsBtn_Click"/>

                    <Border Background="#EEF2FF" 
                            BorderBrush="#CBD5E1" 
                            BorderThickness="1" 
                            CornerRadius="8" 
                            Padding="16,8">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Pitch profile: "
                                       FontFamily="Calibri" 
                                       FontSize="14" 
                                       FontWeight="SemiBold" 
                                       Foreground="{StaticResource TextSecondaryBrush}"/>
                            <TextBlock x:Name="ClassificationText" 
                                       Text="Evaluating..." 
                                       FontFamily="Calibri" 
                                       FontSize="14" 
                                       FontWeight="Bold" 
                                       Foreground="{StaticResource AccentBrush}"
                                       Margin="2,0,0,0"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Recording-wide pitch contour -->
        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="230"/>
                <RowDefinition Height="16"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Style="{StaticResource CardPanel}" Padding="16">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Pitch Contour" FontFamily="Calibri" FontSize="16" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}"/>
                        <TextBlock x:Name="PitchChartSummaryText" Grid.Column="1" Text="Record a sample to see its F0 over time." FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Right" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" Margin="12,0,0,0"/>
                    </Grid>

                    <Grid x:Name="PitchChartHost" Grid.Row="1" ClipToBounds="True" SizeChanged="PitchChartHost_SizeChanged">
                        <Canvas x:Name="PitchChartCanvas" Background="#FBFCFF">
                            <Rectangle x:Name="PitchMasculineBand" Fill="#FEF2F2"/>
                            <Rectangle x:Name="PitchAndrogynousBand" Fill="#FFFBEB"/>
                            <Rectangle x:Name="PitchFeminineBand" Fill="#EFF6FF"/>
                            <Path x:Name="PitchChartGridPath" Stroke="#E2E8F0" StrokeThickness="1"/>
                            <Path x:Name="PitchContourPath" Stroke="{StaticResource AccentBrush}" StrokeThickness="2.5" StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                        </Canvas>

                        <TextBlock x:Name="PitchChartTopLabel" Text="300 Hz" FontSize="10" Foreground="{StaticResource TextSecondaryBrush}" Margin="8,4,0,0" VerticalAlignment="Top" IsHitTestVisible="False"/>
                        <TextBlock x:Name="PitchChartMidLabel" Text="180 Hz" FontSize="10" Foreground="{StaticResource TextSecondaryBrush}" Margin="8,0,0,0" VerticalAlignment="Center" IsHitTestVisible="False"/>
                        <TextBlock x:Name="PitchChartBottomLabel" Text="65 Hz" FontSize="10" Foreground="{StaticResource TextSecondaryBrush}" Margin="8,0,0,16" VerticalAlignment="Bottom" IsHitTestVisible="False"/>
                        <TextBlock x:Name="PitchChartStartTime" Text="0.0 s" FontSize="10" Foreground="{StaticResource TextSecondaryBrush}" Margin="8,0,0,2" VerticalAlignment="Bottom" HorizontalAlignment="Left" IsHitTestVisible="False"/>
                        <TextBlock x:Name="PitchChartMidTime" Text="" FontSize="10" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,2" VerticalAlignment="Bottom" HorizontalAlignment="Center" IsHitTestVisible="False"/>
                        <TextBlock x:Name="PitchChartEndTime" Text="" FontSize="10" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,8,2" VerticalAlignment="Bottom" HorizontalAlignment="Right" IsHitTestVisible="False"/>
                        <TextBlock x:Name="PitchChartStatusText" Text="No reliable voiced pitch was detected." FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" Visibility="Collapsed" IsHitTestVisible="False"/>
                    </Grid>
                </Grid>
            </Border>

            <!-- Main Workspace (2 Columns) -->
            <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.2*"/>
                <ColumnDefinition Width="0.05*"/>
                <ColumnDefinition Width="1*"/>
            </Grid.ColumnDefinitions>

            <!-- Left Column: Metrics Gauges and ASCII Bars -->
            <Border Grid.Column="0" Style="{StaticResource CardPanel}" VerticalAlignment="Stretch">
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <StackPanel Margin="0,0,10,0">
                        <TextBlock Text="Voice Characteristic Metrics" 
                                   FontFamily="Calibri" 
                                   FontSize="16" 
                                   FontWeight="Bold" 
                                   Foreground="{StaticResource TextPrimaryBrush}" 
                                   Margin="0,0,0,16"/>

                        <!-- Metric Blocks -->
                        
                        <!-- PITCH -->
                        <StackPanel Margin="0,0,0,20">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Pitch" FontFamily="Calibri" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}"/>
                                <TextBlock x:Name="PitchRawText" Grid.Column="1" Text="120 Hz" FontFamily="Calibri" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" Margin="8,1,0,0"/>
                            </Grid>
                            <Slider x:Name="PitchGauge" Style="{StaticResource GaugeSliderStyle}" Value="30"/>
                            <Grid Margin="0,-4,0,0">
                                <TextBlock Text="Masc &lt;130" FontSize="10" Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Left"/>
                                <TextBlock Text="145-175" FontSize="10" Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Center"/>
                                <TextBlock Text="Fem &gt;180" FontSize="10" Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Right"/>
                            </Grid>
                        </StackPanel>

                        <!-- SPECTRAL BRIGHTNESS -->
                        <StackPanel Margin="0,0,0,20">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Spectral Brightness" FontFamily="Calibri" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}"/>
                                <TextBlock x:Name="ResRawText" Grid.Column="1" Text="1200 Hz" FontFamily="Calibri" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" Margin="8,1,0,0"/>
                            </Grid>
                            <Slider x:Name="ResGauge" Style="{StaticResource GaugeSliderStyle}" Value="50"/>
                            <Grid Margin="0,-4,0,0">
                                <TextBlock Text="Lower centroid" FontSize="10" Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Left"/>
                                <TextBlock Text="Mid" FontSize="10" Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Center"/>
                                <TextBlock Text="Higher centroid" FontSize="10" Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Right"/>
                            </Grid>
                        </StackPanel>

                        <!-- SPECTRAL BALANCE -->
                        <StackPanel Margin="0,0,0,20">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Spectral Balance" FontFamily="Calibri" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}"/>
                                <TextBlock x:Name="WeightRawText" Grid.Column="1" Text="+4.5 dB" FontFamily="Calibri" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" Margin="8,1,0,0"/>
                            </Grid>
                            <Slider x:Name="WeightGauge" Style="{StaticResource GaugeSliderStyle}" Value="40"/>
                            <Grid Margin="0,-4,0,0">
                                <TextBlock Text="Low-frequency" FontSize="10" Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Left"/>
                                <TextBlock Text="Balanced" FontSize="10" Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Center"/>
                                <TextBlock Text="High-frequency" FontSize="10" Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Right"/>
                            </Grid>
                        </StackPanel>

                        <!-- INTONATION -->
                        <StackPanel Margin="0,0,0,20">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Intonation" FontFamily="Calibri" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}"/>
                                <TextBlock x:Name="IntRawText" Grid.Column="1" Text="1.8 st" FontFamily="Calibri" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" Margin="8,1,0,0"/>
                            </Grid>
                            <Slider x:Name="IntGauge" Style="{StaticResource GaugeSliderStyle}" Value="60"/>
                            <Grid Margin="0,-4,0,0">
                                <TextBlock Text="Steady" FontSize="10" Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Left"/>
                                <TextBlock Text="Moderate" FontSize="10" Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Center"/>
                                <TextBlock Text="Variable" FontSize="10" Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Right"/>
                            </Grid>
                        </StackPanel>

                        <!-- SPEECH PATTERNS -->
                        <StackPanel Margin="0,0,0,10">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Speech Patterns" FontFamily="Calibri" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}"/>
                                <TextBlock x:Name="PatternRawText" Grid.Column="1" Text="3.2 syl/s, falling" FontFamily="Calibri" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" Margin="8,1,0,0"/>
                            </Grid>
                            <Slider x:Name="PatternGauge" Style="{StaticResource GaugeSliderStyle}" Value="80"/>
                            <Grid Margin="0,-4,0,0">
                                <TextBlock Text="Few pauses" FontSize="10" Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Left"/>
                                <TextBlock Text="Mixed" FontSize="10" Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Center"/>
                                <TextBlock Text="More pauses" FontSize="10" Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Right"/>
                            </Grid>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <!-- Right Column: Training Tips and Advice -->
            <Border Grid.Column="2" Style="{StaticResource CardPanel}" VerticalAlignment="Stretch">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" 
                               Text="Vocal Training &amp; Insights" 
                               FontFamily="Calibri" 
                               FontSize="16" 
                               FontWeight="Bold" 
                               Foreground="{StaticResource TextPrimaryBrush}" 
                               Margin="0,0,0,16"/>

                    <TabControl Grid.Row="1" Background="Transparent" BorderThickness="0" Margin="-4,0,-4,0">
                        <TabControl.Resources>
                            <!-- Clean Flat Style for TabItems -->
                            <Style TargetType="TabItem">
                                <Setter Property="HeaderTemplate">
                                    <Setter.Value>
                                        <DataTemplate>
                                            <TextBlock Text="{TemplateBinding Content}" 
                                                       FontFamily="Calibri" 
                                                       FontWeight="Bold" 
                                                       FontSize="11" 
                                                       Margin="8,4"/>
                                        </DataTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="TabItem">
                                            <Border x:Name="Border" 
                                                    BorderBrush="{StaticResource BorderBrush}" 
                                                    BorderThickness="0,0,0,2" 
                                                    Background="Transparent" 
                                                    Margin="0,0,4,0" 
                                                    Cursor="Hand">
                                                <ContentPresenter x:Name="ContentSite" ContentSource="Header"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter TargetName="Border" Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                                                    <Setter Property="TextElement.Foreground" Value="{StaticResource AccentBrush}"/>
                                                </Trigger>
                                                <Trigger Property="IsSelected" Value="False">
                                                    <Setter Property="TextElement.Foreground" Value="{StaticResource TextSecondaryBrush}"/>
                                                </Trigger>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Border" Property="Background" Value="#EDF2F7"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </TabControl.Resources>

                        <!-- PITCH TAB -->
                        <TabItem Header="PITCH">
                            <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="0,16,0,0">
                                <StackPanel>
                                    <TextBlock Text="Understanding Pitch" FontFamily="Calibri" FontWeight="Bold" FontSize="14" Foreground="{StaticResource TextPrimaryBrush}"/>
                                    <TextBlock Text="Pitch refers to the frequency at which your vocal folds vibrate. Shorter, thinner folds create a higher pitch (typically feminine), whereas thicker, longer folds create a lower pitch (typically masculine)." 
                                               TextWrapping="Wrap" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,4,0,12"/>
                                    
                                    <Border Background="#F0F9FF" CornerRadius="8" Padding="12" Margin="0,0,0,12" BorderBrush="#BAE6FD" BorderThickness="1">
                                        <StackPanel>
                                            <TextBlock Text="Tips to raise Pitch (Feminine)" FontFamily="Calibri" FontWeight="Bold" FontSize="12" Foreground="#0369A1"/>
                                            <TextBlock Text="• Practice 'whisper sirens' – whisper and gradually slide your pitch up as if doing a siren. This raises your pitch ceiling safely.&#x0a;• Aim for a target frequency of 190–220 Hz in normal speech.&#x0a;• Keep vocal energy forward in the face (lip buzzes) to reinforce upper frequencies." 
                                                       TextWrapping="Wrap" FontSize="12" Foreground="#0284C7" Margin="0,4,0,0"/>
                                        </StackPanel>
                                    </Border>

                                    <Border Background="#FFF1F2" CornerRadius="8" Padding="12" BorderBrush="#FECDD3" BorderThickness="1">
                                        <StackPanel>
                                            <TextBlock Text="Tips to lower Pitch (Masculine)" FontFamily="Calibri" FontWeight="Bold" FontSize="12" Foreground="#BE123C"/>
                                            <TextBlock Text="• Speak from your diaphragm. Relax your throat and vocalize a deep 'm-hum' down in your chest.&#x0a;• Target a frequency of 90–130 Hz.&#x0a;• Practice speaking at the lower end of your natural pitch range. Avoid tightening your neck muscles." 
                                                       TextWrapping="Wrap" FontSize="12" Foreground="#E11D48" Margin="0,4,0,0"/>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </ScrollViewer>
                        </TabItem>

                        <!-- RESONANCE TAB -->
                        <TabItem Header="SPECTRAL">
                            <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="0,16,0,0">
                                <StackPanel>
                                    <TextBlock Text="Understanding Spectral Brightness" FontFamily="Calibri" FontWeight="Bold" FontSize="14" Foreground="{StaticResource TextPrimaryBrush}"/>
                                    <TextBlock Text="This measurement is the spectral centroid of active speech between 300 and 3000 Hz. Higher values indicate relatively more high-frequency energy. It is not a direct formant or vocal-tract measurement."
                                               TextWrapping="Wrap" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,4,0,12"/>

                                    <Border Background="#F0F9FF" CornerRadius="8" Padding="12" Margin="0,0,0,12" BorderBrush="#BAE6FD" BorderThickness="1">
                                        <StackPanel>
                                    <TextBlock Text="Practice a Brighter Sound" FontFamily="Calibri" FontWeight="Bold" FontSize="12" Foreground="#0369A1"/>
                                            <TextBlock Text="• Swallow-holding or humming with lips closed but teeth apart. Feel the vibration on your lips and nose.&#x0a;• Shorten your vocal tract: lift the larynx slightly (like when you begin a swallow) and bring your tongue forward.&#x0a;• Practice vowels 'ee' and 'oo' to keep the tone bright." 
                                                       TextWrapping="Wrap" FontSize="12" Foreground="#0284C7" Margin="0,4,0,0"/>
                                        </StackPanel>
                                    </Border>

                                    <Border Background="#FFF1F2" CornerRadius="8" Padding="12" BorderBrush="#FECDD3" BorderThickness="1">
                                        <StackPanel>
                                    <TextBlock Text="Practice a Darker Sound" FontFamily="Calibri" FontWeight="Bold" FontSize="12" Foreground="#BE123C"/>
                                            <TextBlock Text="• The Yawn-Sigh: begin a yawn (which drops the larynx) and sigh out. Notice the open, hollow space in your throat.&#x0a;• Relax your tongue and pull it slightly back. Keep your lips rounded.&#x0a;• Speak with a relaxed, slightly dropped jaw to increase the oral cavity volume." 
                                                       TextWrapping="Wrap" FontSize="12" Foreground="#E11D48" Margin="0,4,0,0"/>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </ScrollViewer>
                        </TabItem>

                        <!-- WEIGHT TAB -->
                        <TabItem Header="BALANCE">
                            <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="0,16,0,0">
                                <StackPanel>
                                    <TextBlock Text="Understanding Spectral Balance" FontFamily="Calibri" FontWeight="Bold" FontSize="14" Foreground="{StaticResource TextPrimaryBrush}"/>
                                    <TextBlock Text="This value compares average power in the 80-250 Hz band with 250-3000 Hz. It is useful for comparing recordings made with the same microphone and distance, but it is not a direct measure of vocal-fold closure."
                                               TextWrapping="Wrap" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,4,0,12"/>

                                    <Border Background="#F0F9FF" CornerRadius="8" Padding="12" Margin="0,0,0,12" BorderBrush="#BAE6FD" BorderThickness="1">
                                        <StackPanel>
                                    <TextBlock Text="Practice a Lighter Sound" FontFamily="Calibri" FontWeight="Bold" FontSize="12" Foreground="#0369A1"/>
                                            <TextBlock Text="• Practice 'dog panting' briefly to experience open, light air flow. Transition from a pant to a soft, breathy whisper.&#x0a;• Speak with less vocal effort and smaller volume. Think of whispering with a small tone added.&#x0a;• Avoid heavy vocal fry (that creaky, buzzy low sound)." 
                                                       TextWrapping="Wrap" FontSize="12" Foreground="#0284C7" Margin="0,4,0,0"/>
                                        </StackPanel>
                                    </Border>

                                    <Border Background="#FFF1F2" CornerRadius="8" Padding="12" BorderBrush="#FECDD3" BorderThickness="1">
                                        <StackPanel>
                                    <TextBlock Text="Practice a Fuller Sound" FontFamily="Calibri" FontWeight="Bold" FontSize="12" Foreground="#BE123C"/>
                                            <TextBlock Text="• Use a sharp glottal onset: make a clean, crisp 'ah' sound. Practice getting a firm closure of the folds.&#x0a;• Speak with confidence and chest projection. Think of pushing more air with a firmer buzz.&#x0a;• Accept moderate vocal fry, which naturally occurs in masculine low ranges." 
                                                       TextWrapping="Wrap" FontSize="12" Foreground="#E11D48" Margin="0,4,0,0"/>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </ScrollViewer>
                        </TabItem>

                        <!-- INTONATION TAB -->
                        <TabItem Header="INTONATION">
                            <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="0,16,0,0">
                                <StackPanel>
                                    <TextBlock Text="Understanding Pitch Variation" FontFamily="Calibri" FontWeight="Bold" FontSize="14" Foreground="{StaticResource TextPrimaryBrush}"/>
                                    <TextBlock Text="Intonation here is the standard deviation of tracked pitch in semitones. A larger value means a wider pitch contour in this recording; it does not determine a listener's perception of gender."
                                               TextWrapping="Wrap" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,4,0,12"/>

                                    <Border Background="#F0F9FF" CornerRadius="8" Padding="12" Margin="0,0,0,12" BorderBrush="#BAE6FD" BorderThickness="1">
                                        <StackPanel>
                                            <TextBlock Text="Practice Wider Pitch Variation" FontFamily="Calibri" FontWeight="Bold" FontSize="12" Foreground="#0369A1"/>
                                            <TextBlock Text="• Read aloud and exaggerate your pitch variations. Bounce up on important keywords.&#x0a;• Sweep your pitch upward at the end of sentences to convey softness or engagement.&#x0a;• Avoid a flat, uniform monotone voice." 
                                                       TextWrapping="Wrap" FontSize="12" Foreground="#0284C7" Margin="0,4,0,0"/>
                                        </StackPanel>
                                    </Border>

                                    <Border Background="#FFF1F2" CornerRadius="8" Padding="12" BorderBrush="#FECDD3" BorderThickness="1">
                                        <StackPanel>
                                            <TextBlock Text="Practice a Steadier Pitch" FontFamily="Calibri" FontWeight="Bold" FontSize="12" Foreground="#BE123C"/>
                                            <TextBlock Text="• Maintain a steady, narrow pitch range. Deliver phrases flatly.&#x0a;• Step down in pitch at the end of a statement to indicate finality and authority.&#x0a;• Keep a calm, steady cadence without dramatic pitches for emphasis." 
                                                       TextWrapping="Wrap" FontSize="12" Foreground="#E11D48" Margin="0,4,0,0"/>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </ScrollViewer>
                        </TabItem>

                        <!-- SPEECH PATTERNS TAB -->
                        <TabItem Header="TIMING">
                            <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="0,16,0,0">
                                <StackPanel>
                                    <TextBlock Text="Understanding Speech Timing" FontFamily="Calibri" FontWeight="Bold" FontSize="14" Foreground="{StaticResource TextPrimaryBrush}"/>
                                    <TextBlock Text="Timing summarizes pauses, an amplitude-envelope pacing estimate, and the direction of the final half-second of voiced pitch. These measurements describe the recording; they are not used to infer gender."
                                               TextWrapping="Wrap" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,4,0,12"/>

                                    <Border Background="#F0F9FF" CornerRadius="8" Padding="12" Margin="0,0,0,12" BorderBrush="#BAE6FD" BorderThickness="1">
                                        <StackPanel>
                                            <TextBlock Text="Try More Pausing" FontFamily="Calibri" FontWeight="Bold" FontSize="12" Foreground="#0369A1"/>
                                            <TextBlock Text="• Pause for breath between phrases. Let your breathing be audible and relaxed.&#x0a;• Soften hard consonants (like 'k', 't', 'p') and blend words together smoothly.&#x0a;• Practice using welcoming, open phrases with gentle starts." 
                                                       TextWrapping="Wrap" FontSize="12" Foreground="#0284C7" Margin="0,4,0,0"/>
                                        </StackPanel>
                                    </Border>

                                    <Border Background="#FFF1F2" CornerRadius="8" Padding="12" BorderBrush="#FECDD3" BorderThickness="1">
                                        <StackPanel>
                                            <TextBlock Text="Try a More Continuous Delivery" FontFamily="Calibri" FontWeight="Bold" FontSize="12" Foreground="#BE123C"/>
                                            <TextBlock Text="• Use sharp, crisp articulation. Enounce consonants clearly and sharply.&#x0a;• Speak in direct, complete thoughts with fewer pauses. Let the voice flow continuously.&#x0a;• End sentences with a firm, dropping tone instead of a questioning, rising curl." 
                                                       TextWrapping="Wrap" FontSize="12" Foreground="#E11D48" Margin="0,4,0,0"/>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </ScrollViewer>
                        </TabItem>
                    </TabControl>
                </Grid>
            </Border>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
