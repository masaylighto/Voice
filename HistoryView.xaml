<UserControl x:Class="Voice.HistoryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Voice"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="800"
             TextOptions.TextFormattingMode="Display"
             UseLayoutRounding="True">
    <Grid Background="Transparent" Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0">
                <TextBlock Text="Vocal History Log" 
                           FontFamily="Calibri" 
                           FontSize="26" 
                           FontWeight="Bold" 
                           Foreground="{StaticResource TextPrimaryBrush}"/>
                <TextBlock Text="Track your progress over time. Load past reports or replay recordings." 
                           FontFamily="Calibri" 
                           FontSize="13" 
                           Foreground="{StaticResource TextSecondaryBrush}"/>
            </StackPanel>
            
            <Button x:Name="RefreshBtn" 
                    Grid.Column="1" 
                    Style="{StaticResource PrimaryButton}" 
                    Background="#E2E8F0" 
                    Foreground="{StaticResource TextPrimaryBrush}" 
                    Padding="14,8" 
                    VerticalAlignment="Center"
                    Click="RefreshBtn_Click">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="&#xE72C;" FontFamily="Segoe MDL2 Assets" FontSize="11" Margin="0,0,6,0" VerticalAlignment="Center"/>
                    <TextBlock Text="Refresh" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>
        </Grid>

        <!-- History ListView -->
        <Grid Grid.Row="1">
            <!-- Empty state illustration if list is empty -->
            <StackPanel x:Name="EmptyStatePanel" 
                        HorizontalAlignment="Center" 
                        VerticalAlignment="Center"
                        Visibility="Collapsed">
                <TextBlock Text="No Sessions Saved Yet" 
                           FontFamily="Calibri" 
                           FontSize="16" 
                           FontWeight="Bold" 
                           Foreground="{StaticResource TextSecondaryBrush}" 
                           HorizontalAlignment="Center"/>
                <TextBlock Text="Record your voice in the Capture tab and save it to start logging history." 
                           FontFamily="Calibri" 
                           FontSize="12" 
                           Foreground="#A0AEC0" 
                           HorizontalAlignment="Center" 
                           Margin="0,4,0,16"/>
            </StackPanel>

            <ListView x:Name="HistoryListView" 
                      Background="Transparent" 
                      BorderThickness="0" 
                      ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                      ScrollViewer.VerticalScrollBarVisibility="Auto">
                <ListView.ItemContainerStyle>
                    <Style TargetType="ListViewItem">
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Padding" Value="0"/>
                        <Setter Property="Margin" Value="0,0,0,12"/>
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        <!-- Disable default blue selection highlights -->
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListViewItem">
                                    <ContentPresenter/>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListView.ItemContainerStyle>
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Border Style="{StaticResource CardPanel}" Padding="16,14">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="2*"/>
                                    <ColumnDefinition Width="1.5*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <!-- Session Title & Classification -->
                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding VoiceClassification}" 
                                               FontFamily="Calibri" 
                                               FontSize="15" 
                                               FontWeight="Bold" 
                                               Foreground="{StaticResource AccentBrush}"/>
                                    <TextBlock Text="{Binding Timestamp, StringFormat='{}{0:MMMM dd, yyyy  hh:mm tt}'}" 
                                               FontFamily="Calibri" 
                                               FontSize="11" 
                                               Foreground="{StaticResource TextSecondaryBrush}" 
                                               Margin="0,2,0,0"/>
                                </StackPanel>

                                <!-- Mid Info: Averages -->
                                <StackPanel Grid.Column="1" VerticalAlignment="Center" Orientation="Horizontal">
                                    <StackPanel Margin="0,0,24,0">
                                        <TextBlock Text="Pitch" FontSize="10" FontWeight="Bold" Foreground="{StaticResource TextSecondaryBrush}"/>
                                        <TextBlock Text="{Binding AveragePitchHz, StringFormat='{}{0:0} Hz'}" FontSize="13" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,1,0,0"/>
                                    </StackPanel>
                                    <StackPanel Margin="0,0,24,0">
                                        <TextBlock Text="Resonance" FontSize="10" FontWeight="Bold" Foreground="{StaticResource TextSecondaryBrush}"/>
                                        <TextBlock Text="{Binding AverageResonanceHz, StringFormat='{}{0:0} Hz'}" FontSize="13" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,1,0,0"/>
                                    </StackPanel>
                                    <StackPanel>
                                        <TextBlock Text="Weight" FontSize="10" FontWeight="Bold" Foreground="{StaticResource TextSecondaryBrush}"/>
                                        <TextBlock Text="{Binding AverageWeightDb, StringFormat='{}{0:0.0} dB'}" FontSize="13" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,1,0,0"/>
                                    </StackPanel>
                                </StackPanel>

                                <!-- Right Column: Control Buttons -->
                                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                    <Button Style="{StaticResource PrimaryButton}" 
                                            Background="#10B981" 
                                            Padding="12,6" 
                                            FontSize="11" 
                                            Margin="0,0,8,0"
                                            Click="PlayRecord_Click">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="&#xE768;" FontFamily="Segoe MDL2 Assets" FontSize="10" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                            <TextBlock Text="Play" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>
                                    
                                    <Button Style="{StaticResource PrimaryButton}" 
                                            Padding="12,6" 
                                            FontSize="11" 
                                            Margin="0,0,8,0"
                                            Click="LoadRecord_Click">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="&#xE8A5;" FontFamily="Segoe MDL2 Assets" FontSize="10" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                            <TextBlock Text="Load Report" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>
                                    
                                    <Button Style="{StaticResource PrimaryButton}" 
                                            Background="#EF4444" 
                                            Padding="10,6" 
                                            FontSize="11"
                                            Click="DeleteRecord_Click">
                                        <TextBlock Text="&#xE74D;" FontFamily="Segoe MDL2 Assets" VerticalAlignment="Center"/>
                                    </Button>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </Grid>
    </Grid>
</UserControl>
