<Window x:Class="Voice.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Voice"
        mc:Ignorable="d"
        Title="Voice Lab - Vocal Analyzer &amp; Trainer" 
        Icon="assets/app_icon.png"
        Height="700" Width="1100"
        MinWidth="950" MinHeight="620"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource WindowBgBrush}"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType"
        UseLayoutRounding="True"
        FontFamily="Calibri"
        StateChanged="Window_StateChanged">
    
    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="40" 
                      ResizeBorderThickness="6" 
                      GlassFrameThickness="0" 
                      CornerRadius="0"/>
    </WindowChrome.WindowChrome>

    <!-- Outer 1px premium border that highlights the custom window shell -->
    <Border x:Name="MainBorder" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
        <Grid>
            <Grid.ColumnDefinitions>
                <!-- Left Sidebar Column -->
                <ColumnDefinition Width="240"/>
                <!-- Main Workspace Column -->
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Grid.RowDefinitions>
                <!-- Title Bar Row -->
                <RowDefinition Height="40"/>
                <!-- Content Workspace Row -->
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- ================= SIDEBAR PANEL ================= -->
            <!-- Spans both rows on the left. Sidebar background is pure white -->
            <Border Grid.Row="0" Grid.RowSpan="2" Grid.Column="0" 
                    Background="#FFFFFF" 
                    BorderBrush="{StaticResource BorderBrush}" 
                    BorderThickness="0,0,1,0">
                <Grid Margin="16,0,16,16">
                    <Grid.RowDefinitions>
                        <!-- App Brand Header aligning with Titlebar -->
                        <RowDefinition Height="40"/>
                        <RowDefinition Height="24"/>
                        <!-- Navigation list -->
                        <RowDefinition Height="*"/>
                        <!-- Footer -->
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Branding Header (drag-enabled via WindowChrome) -->
                    <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Path Data="M12,2A3,3,0,0,0,9,5v6a3,3,0,0,0,6,0V5A3,3,0,0,0,12,2m6,9a6,6,0,0,1-12,0H4a8,8,0,0,0,7.2,7.9V21H9v2h6V21H12.8A8,8,0,0,0,20,11Z"
                              Fill="{StaticResource AccentBrush}"
                              Width="18" Height="18"
                              Stretch="Uniform"
                              Margin="0,0,8,0"/>
                        <TextBlock Text="Voice Lab" 
                                   FontFamily="Calibri" 
                                   FontSize="20" 
                                   FontWeight="Bold" 
                                   Foreground="{StaticResource TextPrimaryBrush}" 
                                   VerticalAlignment="Center"/>
                    </StackPanel>

                    <!-- Navigation options (radio buttons) -->
                    <StackPanel Grid.Row="2" Margin="0,12,0,0">
                        <RadioButton x:Name="NavCapture" 
                                     Style="{StaticResource NavButton}" 
                                     IsChecked="True"
                                     Checked="Nav_Checked">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE720;" FontFamily="Segoe MDL2 Assets" FontSize="13.5" Margin="0,0,12,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Capture Voice" VerticalAlignment="Center"/>
                            </StackPanel>
                        </RadioButton>
                        
                        <RadioButton x:Name="NavAnalysis" 
                                     Style="{StaticResource NavButton}"
                                     Checked="Nav_Checked">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE9D2;" FontFamily="Segoe MDL2 Assets" FontSize="13.5" Margin="0,0,12,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Detailed Analysis" VerticalAlignment="Center"/>
                            </StackPanel>
                        </RadioButton>
                        

                        <RadioButton x:Name="NavHistory" 
                                     Style="{StaticResource NavButton}"
                                     Checked="Nav_Checked">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE8F4;" FontFamily="Segoe MDL2 Assets" FontSize="13.5" Margin="0,0,12,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Session History" VerticalAlignment="Center"/>
                            </StackPanel>
                        </RadioButton>
                    </StackPanel>

                    <!-- Footer branding -->
                    <StackPanel Grid.Row="3" HorizontalAlignment="Center">
                        <TextBlock Text="Voice Lab v1.0.0" 
                                   FontSize="11" 
                                   FontWeight="Bold"
                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                        <TextBlock Text="Custom Shell Mode" 
                                   FontSize="10" 
                                   Foreground="#A0AEC0" 
                                   HorizontalAlignment="Center"
                                   Margin="0,1,0,0"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ================= CUSTOM RIGHT TITLEBAR ================= -->
            <Border Grid.Row="0" Grid.Column="1" 
                    Background="#F8FAFC"
                    BorderBrush="{StaticResource BorderBrush}" 
                    BorderThickness="0,0,0,1">
                <Grid>
                    <!-- Small title label for visual balance -->
                    <TextBlock Text="Voice Testing Suite" 
                               FontSize="11.5" 
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextSecondaryBrush}" 
                               VerticalAlignment="Center" 
                               Margin="16,0,0,0"
                               IsHitTestVisible="False"/>

                    <!-- Custom Minimize / Maximize / Close Buttons -->
                    <StackPanel Orientation="Horizontal" 
                                HorizontalAlignment="Right" 
                                VerticalAlignment="Stretch"
                                WindowChrome.IsHitTestVisibleInChrome="True">
                        
                        <!-- Minimize Button -->
                        <Button x:Name="BtnMinimize" 
                                Width="46" Height="39" 
                                Background="Transparent" 
                                BorderThickness="0"
                                Click="BtnMinimize_Click"
                                Focusable="False">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="Bg" Background="Transparent">
                                        <TextBlock Text="&#xE921;" FontFamily="Segoe MDL2 Assets" FontSize="10" Foreground="{StaticResource TextPrimaryBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Bg" Property="Background" Value="#E2E8F0"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        
                        <!-- Maximize Button -->
                        <Button x:Name="BtnMaximize" 
                                Width="46" Height="39" 
                                Background="Transparent" 
                                BorderThickness="0"
                                Click="BtnMaximize_Click"
                                Focusable="False">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="Bg" Background="Transparent">
                                        <TextBlock x:Name="Icon" Text="&#xE922;" FontFamily="Segoe MDL2 Assets" FontSize="10" Foreground="{StaticResource TextPrimaryBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Bg" Property="Background" Value="#E2E8F0"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        
                        <!-- Close Button -->
                        <Button x:Name="BtnClose" 
                                Width="46" Height="39" 
                                Background="Transparent" 
                                BorderThickness="0"
                                Click="BtnClose_Click"
                                Focusable="False">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="Bg" Background="Transparent">
                                        <TextBlock x:Name="Txt" Text="&#xE8BB;" FontFamily="Segoe MDL2 Assets" FontSize="10" Foreground="{StaticResource TextPrimaryBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Bg" Property="Background" Value="#EF4444"/>
                                            <Setter TargetName="Txt" Property="Foreground" Value="White"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ================= CONTENT WORKSPACE ================= -->
            <!-- Located in Row 1, Column 1 -->
            <Grid Grid.Row="1" Grid.Column="1" Margin="8">
                <!-- Capture Dashboard View -->
                <local:DashboardView x:Name="DashboardPanel" 
                                     Visibility="Visible"/>

                <!-- Analysis Dashboard View -->
                <local:AnalysisView x:Name="AnalysisPanel" 
                                    Visibility="Collapsed"/>


                <!-- History log panel -->
                <local:HistoryView x:Name="HistoryPanel" 
                                   Visibility="Collapsed"/>
            </Grid>
        </Grid>
    </Border>
</Window>
